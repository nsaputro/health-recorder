# Application Settings
APP_SECRET_KEY=your-super-secret-key-change-this-in-production
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=sqlite:///./health_recorder.db

# Google OAuth2 Credentials
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Google Sheets (optional — leave blank to auto-create a new spreadsheet)
GOOGLE_SHEETS_SPREADSHEET_ID=

# Scopes requested from Google
# fitness.body: weight, BMI
# fitness.blood_pressure: blood pressure
# fitness.blood_glucose: blood glucose
# spreadsheets: Google Sheets read/write
